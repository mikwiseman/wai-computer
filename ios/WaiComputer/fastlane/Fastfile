require "json"

default_platform(:ios)

def waicomputer_app_store_connect_api_key
  config_path = File.expand_path(ENV.fetch("APPSTORECONNECT_CONFIG"))
  config = JSON.parse(File.read(config_path))

  app_store_connect_api_key(
    key_id: config.fetch("key_id"),
    issuer_id: config.fetch("issuer_id"),
    key_filepath: File.expand_path(config.fetch("key_filepath")),
    in_house: false
  )
end

platform :ios do
  desc "Build and upload to TestFlight"
  lane :testflight_upload do
    api_key = waicomputer_app_store_connect_api_key

    build_app(
      project: "WaiComputeriOS.xcodeproj",
      scheme: "WaiComputer",
      export_method: "app-store",
      output_directory: "build",
      output_name: "WaiComputer.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
