# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/waisay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=waisay

# App
DEBUG=false

# Auth - JWT_SECRET is REQUIRED (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-key-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
AUTH_COOKIE_SECURE=

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","https://wai.computer","https://api.wai.computer"]

# Voice runtime
SPEECH_TO_TEXT_PROVIDER=elevenlabs
REALTIME_VOICE_PROVIDER=elevenlabs

# ElevenLabs (realtime voice + optional STT)
ELEVENLABS_API_KEY=
ELEVENLABS_CONVERSATION_AGENT_ID=
ELEVENLABS_RECORDING_AGENT_ID=
ELEVENLABS_SPEECH_TO_TEXT_MODEL=scribe_v2
ELEVENLABS_REALTIME_SPEECH_TO_TEXT_MODEL=scribe_v2_realtime
ELEVENLABS_ENVIRONMENT=production

# Claude/Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
APP_BUILDER_GENERATION_PROVIDER=auto
APP_BUILDER_DEFAULT_DEPLOYMENT_TARGET=auto
AGENT_SDK_MODEL=claude-sonnet-4-20250514
AGENT_SDK_EFFORT=high
AGENT_SDK_MAX_BUDGET_USD=1.0
AGENT_SDK_MAX_TURNS=10

# Agent system
AGENT_MODEL=claude-haiku-4-5
AGENT_MAX_TURNS=10
AGENT_RATE_LIMIT_PER_MINUTE=30
AGENT_RATE_LIMIT_PER_HOUR=200

# Uploads
UPLOAD_MAX_BYTES=209715200
UPLOAD_STAGING_DIR=/tmp/waisay/uploads

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=WaiSay <noreply@mail.waiwai.is>

# Frontend URL for magic links
FRONTEND_URL=https://wai.computer

# Redis (for Celery agent scheduling)
REDIS_URL=redis://localhost:6379/0

# Cloudflare (for Pages + Workers deploy targets)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Sentry (error tracking — optional)
SENTRY_DSN=
