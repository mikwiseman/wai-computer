# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/waicomputer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=waicomputer

# App
DEBUG=false

# Auth - JWT_SECRET is REQUIRED (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-key-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
AUTH_COOKIE_SECURE=

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","https://wai.computer"]

# Voice runtime
REALTIME_VOICE_PROVIDER=elevenlabs

# ElevenLabs (realtime conversational voice agents)
ELEVENLABS_API_KEY=
ELEVENLABS_CONVERSATION_AGENT_ID=
ELEVENLABS_RECORDING_AGENT_ID=
ELEVENLABS_ENVIRONMENT=production
# Scribe batch STT drops filler words; set false for verbatim transcripts.
ELEVENLABS_STT_NO_VERBATIM=true

# xAI (server-side summary text-to-speech)
XAI_API_KEY=
SUMMARY_AUDIO_PROVIDER=xai
SUMMARY_AUDIO_MODEL=xai-text-to-speech
SUMMARY_AUDIO_VOICE_ID=ara
SUMMARY_AUDIO_LANGUAGE=auto
SUMMARY_AUDIO_STORAGE_DIR=/var/lib/waicomputer/summary-audio
SUMMARY_AUDIO_MAX_CHARS=12000
SUMMARY_AUDIO_CODEC=mp3
SUMMARY_AUDIO_USER_DAILY_CHARS_CAP=100000
SUMMARY_AUDIO_GLOBAL_DAILY_CHARS_CAP=1000000

# Deepgram (realtime dictation + live + batch file transcription)
DEEPGRAM_API_KEY=

# OpenAI (Companion + OCR + comparisons + memory tasks + embeddings)
OPENAI_API_KEY=your-openai-key
OPENAI_LLM_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Cerebras (summaries + dictation cleanup/translation)
CEREBRAS_API_KEY=your-cerebras-key
CEREBRAS_API_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_LLM_MODEL=gpt-oss-120b

# Telegram bot integration. TELEGRAM_API_ID/HASH power the local Bot API
# service used for >20 MB audio/video imports.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=waicomputer_bot
TELEGRAM_WEBHOOK_SECRET_TOKEN=your-random-webhook-secret
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash
TELEGRAM_DOWNLOAD_MAX_BYTES=1073741824

# Uploads
# 1 GiB: video imports upload the original container when the client can't
# extract audio locally; the worker reduces it to FLAC before STT.
UPLOAD_MAX_BYTES=1073741824
UPLOAD_STAGING_DIR=/tmp/waicomputer/uploads

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=WaiComputer <noreply@mail.waiwai.is>

# Frontend URL for magic links
FRONTEND_URL=https://wai.computer
AUTH_COOKIE_DOMAIN=wai.computer

# Redis (for Celery agent scheduling)
REDIS_URL=redis://localhost:6379/0

# Cloudflare (for Pages + Workers deploy targets)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Sentry (error tracking — optional)
SENTRY_DSN=
