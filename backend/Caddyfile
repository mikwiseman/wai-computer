www.wai.computer {
    redir https://wai.computer{uri} permanent
}

wai.computer {
    handle_path /releases/macos/* {
        root * /srv/releases/macos
        file_server
        header Cache-Control "public, max-age=300"
    }

    handle_path /releases/android/* {
        root * /srv/releases/android
        file_server
        header Cache-Control "public, max-age=300"
        @apk path *.apk
        header @apk Content-Type "application/vnd.android.package-archive"
    }

    handle /api/* {
        reverse_proxy api:8000
    }

    handle /mcp {
        reverse_proxy api:8000
    }

    handle /.well-known/oauth-* {
        reverse_proxy api:8000
    }

    handle /authorize {
        reverse_proxy api:8000
    }

    handle /token {
        reverse_proxy api:8000
    }

    handle /revoke {
        reverse_proxy api:8000
    }

    @mcpRegistration {
        method POST OPTIONS
        path /register
    }
    handle @mcpRegistration {
        reverse_proxy api:8000
    }

    @health path /health /health/*
    handle @health {
        reverse_proxy api:8000
    }

    handle {
        reverse_proxy web:3000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        -Server
    }

    request_body {
        max_size 200MB
    }

}
