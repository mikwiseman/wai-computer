# No www site block: www.wai.computer has no DNS record, so ACME validation can
# never succeed — Let's Encrypt paused the account for that hostname after
# repeated failures. Re-add only after creating the DNS record at the edge.

# HTTP/3 is OFF here on purpose: public traffic terminates at the wai-ru edge
# proxy (63.250.57.133, /etc/caddy on that host), which serves h3 to browsers
# and proxies to this origin over TCP. This origin's only client is that edge,
# so advertising h3 here would be dead weight — and an advertised-but-
# unreachable h3 endpoint is actively harmful (browsers cache Alt-Svc for 30
# days and race the blackhole; observed as 30-44s page-load stalls before the
# edge's udp/443 was opened on 2026-07-20).
{
    servers {
        protocols h1 h2
    }
}

# Local-only health endpoint for the Docker healthcheck: plain HTTP on the
# container loopback, no TLS handshake and no round-trip through the public
# edge proxy.
http://127.0.0.1 {
    respond /health "ok" 200
}

wai.computer {
    handle_path /releases/macos/* {
        root * /srv/releases/macos
        file_server
        header Cache-Control "public, max-age=300"
    }

    handle /api/* {
        reverse_proxy api:8000
    }

    handle /mcp {
        reverse_proxy api:8000
    }

    handle /.well-known/oauth-* {
        reverse_proxy api:8000
    }

    handle /authorize {
        reverse_proxy api:8000
    }

    handle /token {
        reverse_proxy api:8000
    }

    handle /revoke {
        reverse_proxy api:8000
    }

    @mcpRegistration {
        method POST OPTIONS
        path /register
    }
    handle @mcpRegistration {
        reverse_proxy api:8000
    }

    @health path /health /health/*
    handle @health {
        reverse_proxy api:8000
    }

    handle {
        reverse_proxy web:3000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        -Server
    }

    request_body {
        max_size 200MB
    }

}
