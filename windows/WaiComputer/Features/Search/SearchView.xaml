<Page
    x:Class="WaiComputer.Features.Search.SearchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="24" Spacing="12">
        <TextBlock Text="Search" Style="{ThemeResource WaiPageTitle}" />
        <AutoSuggestBox x:Name="SearchBox" PlaceholderText="Search transcripts, summaries, people…" QueryIcon="Find" />
        <ListView x:Name="ResultsList" />
    </StackPanel>
</Page>
