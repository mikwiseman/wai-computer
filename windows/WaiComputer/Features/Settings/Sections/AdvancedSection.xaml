<UserControl
    x:Class="WaiComputer.Features.Settings.Sections.AdvancedSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12">
        <TextBlock Text="ADVANCED" Style="{StaticResource WaiSectionHeader}" />
        <ToggleSwitch x:Name="AutoStartToggle" Header="Start with Windows" />
        <Button Content="Reveal local data folder" Click="OnRevealData" />
        <Button Content="Reset session" Click="OnResetSession" />
    </StackPanel>
</UserControl>
