<UserControl
    x:Class="WaiComputer.Features.Settings.Sections.UpdatesSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12">
        <TextBlock Text="UPDATES" Style="{StaticResource WaiSectionHeader}" />
        <ToggleSwitch x:Name="BetaToggle" Header="Receive beta updates"
                      OffContent="Stable channel" OnContent="Beta channel" />
        <Button Content="Check for updates now" Click="OnCheck" />
        <TextBlock x:Name="VersionLabel" Style="{ThemeResource CaptionTextBlockStyle}" />
    </StackPanel>
</UserControl>
