<Window
    x:Class="WaiComputer.Features.Onboarding.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="48" RowDefinitions="*,Auto">
        <Frame x:Name="SlideFrame" Grid.Row="0" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button x:Name="BackButton" Content="Back" Click="OnBack" />
            <Button x:Name="NextButton" Content="Next" Style="{ThemeResource AccentButtonStyle}" Click="OnNext" />
        </StackPanel>
    </Grid>
</Window>
