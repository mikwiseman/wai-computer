<Page
    x:Class="WaiComputer.Features.Onboarding.Slides.DictationSandboxSlide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" VerticalAlignment="Center" MaxWidth="540">
        <TextBlock Text="Try dictation" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock TextWrapping="Wrap">
            Hold your chosen hotkey and speak. Release when you're done.
            The text will appear in this box.
        </TextBlock>
        <TextBox PlaceholderText="Your dictated text will appear here…" AcceptsReturn="True" Height="120" />
        <TextBlock Text="When you're ready, click Finish to start using WaiComputer." Style="{ThemeResource CaptionTextBlockStyle}" />
    </StackPanel>
</Page>
