<Page
    x:Class="WaiComputer.Features.Onboarding.Slides.ValuePropsSlide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="24" VerticalAlignment="Center">
        <TextBlock Text="What you can do with WaiComputer" Style="{ThemeResource TitleTextBlockStyle}" />
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="8">
                <FontIcon Glyph="&#xE720;" FontSize="32" />
                <TextBlock Text="Record mic + system audio" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Capture both sides of any meeting from Zoom, Teams, Discord, or Slack calls." TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="8">
                <FontIcon Glyph="&#xE8BD;" FontSize="32" />
                <TextBlock Text="Live transcripts + summaries" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Read along while you talk. We turn recordings into searchable transcripts and AI summaries." TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="8">
                <FontIcon Glyph="&#xE765;" FontSize="32" />
                <TextBlock Text="Dictate anywhere" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Hold the hotkey, speak, release — your text appears in whatever app has focus." TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </StackPanel>
</Page>
