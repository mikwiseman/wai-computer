<Page
    x:Class="WaiComputer.Features.Onboarding.Slides.HotkeyPickerSlide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" VerticalAlignment="Center" MaxWidth="480">
        <TextBlock Text="Pick a dictation hotkey" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock Text="Hold to dictate, double-tap to toggle hands-free." TextWrapping="Wrap" />
        <ComboBox x:Name="HotkeyCombo" Header="Hotkey">
            <ComboBoxItem Content="Right Alt (recommended)" IsSelected="True" Tag="RightAlt" />
            <ComboBoxItem Content="Left Alt" Tag="LeftAlt" />
            <ComboBoxItem Content="Right Ctrl" Tag="RightCtrl" />
            <ComboBoxItem Content="Right Win" Tag="RightWin" />
            <ComboBoxItem Content="Caps Lock (re-purposed)" Tag="CapsLock" />
            <ComboBoxItem Content="Ctrl + Alt" Tag="CtrlAlt" />
        </ComboBox>
        <InfoBar Title="Warning" Severity="Warning"
                 Message="Left Alt and Right Win conflict with Windows shortcuts. Pick another if you use those often."
                 IsOpen="False" x:Name="WarnInfoBar" IsClosable="False" />
    </StackPanel>
</Page>
