<Page
    x:Class="WaiComputer.Features.Onboarding.Slides.LanguagesSlide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" VerticalAlignment="Center" MaxWidth="480">
        <TextBlock Text="Languages" Style="{ThemeResource TitleTextBlockStyle}" />
        <ComboBox Header="Primary language" SelectedIndex="0">
            <ComboBoxItem Content="Auto-detect" Tag="multi" />
            <ComboBoxItem Content="English" Tag="en" />
            <ComboBoxItem Content="Русский" Tag="ru" />
        </ComboBox>
        <ComboBox Header="Summary language" SelectedIndex="0">
            <ComboBoxItem Content="Same as primary" Tag="auto" />
            <ComboBoxItem Content="English" Tag="en" />
            <ComboBoxItem Content="Русский" Tag="ru" />
        </ComboBox>
    </StackPanel>
</Page>
