<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Wai brand colours. Override Fluent accent so primary buttons + selection match. -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="WaiAccentColor">#FF0E4DEA</Color>
            <Color x:Key="WaiAccentSecondaryColor">#FF8FB1FF</Color>
            <SolidColorBrush x:Key="WaiAccentBrush" Color="{StaticResource WaiAccentColor}" />
            <SolidColorBrush x:Key="WaiAccentSecondaryBrush" Color="{StaticResource WaiAccentSecondaryColor}" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource WaiAccentColor}" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource WaiAccentColor}" Opacity="0.85" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource WaiAccentColor}" Opacity="0.7" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="WaiAccentColor">#FF6E94FF</Color>
            <Color x:Key="WaiAccentSecondaryColor">#FF1F2D62</Color>
            <SolidColorBrush x:Key="WaiAccentBrush" Color="{StaticResource WaiAccentColor}" />
            <SolidColorBrush x:Key="WaiAccentSecondaryBrush" Color="{StaticResource WaiAccentSecondaryColor}" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource WaiAccentColor}" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource WaiAccentColor}" Opacity="0.85" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource WaiAccentColor}" Opacity="0.7" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Spacing -->
    <x:Double x:Key="WaiSpacingXs">4</x:Double>
    <x:Double x:Key="WaiSpacingSm">8</x:Double>
    <x:Double x:Key="WaiSpacingMd">16</x:Double>
    <x:Double x:Key="WaiSpacingLg">24</x:Double>
    <x:Double x:Key="WaiSpacingXl">48</x:Double>

    <!-- Section header style -->
    <Style x:Key="WaiSectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ContentControlThemeFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="120" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="Margin" Value="0,16,0,8" />
    </Style>

    <!-- Page heading -->
    <Style x:Key="WaiPageTitle" TargetType="TextBlock" BasedOn="{StaticResource TitleLargeTextBlockStyle}">
        <Setter Property="Margin" Value="24,16,24,8" />
    </Style>
</ResourceDictionary>
