require "json"
require "shellwords"

default_platform(:ios)

def repo_root
  File.expand_path("..", __dir__)
end

def strip_quarantine_attributes(*paths)
  paths.each do |path|
    next unless File.exist?(path)

    sh("find #{path.shellescape} -xattrname com.apple.quarantine -exec xattr -d com.apple.quarantine {} +")
  end
end

def waicomputer_app_store_connect_api_key
  config_path = File.expand_path("~/.appstoreconnect/config.json")
  config = JSON.parse(File.read(config_path))

  app_store_connect_api_key(
    key_id: config.fetch("key_id"),
    issuer_id: config.fetch("issuer_id"),
    key_filepath: File.expand_path(config.fetch("key_filepath")),
    in_house: false
  )
end

platform :ios do
  desc "Upload iOS metadata and screenshots to App Store Connect"
  lane :upload_metadata do |options|
    api_key = waicomputer_app_store_connect_api_key

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.computer",
      app_version: options[:app_version] || "1.0.7",
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Submit latest uploaded iOS build for App Review"
  lane :submit_for_review do |options|
    api_key = waicomputer_app_store_connect_api_key

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.computer",
      build_number: options[:build_number],
      app_version: options[:app_version] || "1.0.7",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end

platform :android do
  desc "Upload Android AAB to Google Play internal track"
  lane :upload_internal do
    upload_to_play_store(
      package_name: "is.waiwai.computer",
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key: File.expand_path("~/.google-play/service-account.json"),
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      validate_only: false
    )
  end
end

platform :mac do
  # macOS ships only via the Direct DMG channel (Developer ID + Sparkle).
  # Mac App Store / TestFlight was retired; iOS still uses TestFlight via the
  # ios platform above.

  desc "Build strict notarized DMG and publish it to wai.computer"
  lane :publish_dmg do
    strip_quarantine_attributes(
      File.join(repo_root, "macos/WaiComputer/WaiComputer/AppIcon.icon"),
      File.join(repo_root, "macos/WaiComputer/WaiComputer/Assets.xcassets")
    )
    sh("MACOS_RELEASE_STRICT=1 #{File.join(repo_root, "scripts/build-macos-dmg.sh")}")
    sh(File.join(repo_root, "scripts/publish-macos-dmg.sh"))
  end

  desc "Build strict notarized DMG and publish it to wai.computer (alias for publish_dmg)"
  lane :upload_all do
    publish_dmg
  end
end
