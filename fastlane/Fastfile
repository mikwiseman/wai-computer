default_platform(:ios)

def waisay_app_store_connect_api_key
  app_store_connect_api_key(
    key_id: "TND8C962YA",
    issuer_id: "db1b8a2b-2870-44dc-baf5-bbc2a17db1a3",
    key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_TND8C962YA.p8"),
    in_house: false
  )
end

platform :ios do
  desc "Upload iOS metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = waisay_app_store_connect_api_key

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.say",
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Submit latest uploaded iOS build for App Review"
  lane :submit_for_review do |options|
    api_key = waisay_app_store_connect_api_key

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.say",
      build_number: options[:build_number],
      app_version: options[:app_version] || "1.0.3",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end

platform :android do
  desc "Upload Android AAB to Google Play internal track"
  lane :upload_internal do
    upload_to_play_store(
      package_name: "is.waiwai.say",
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key: File.expand_path("~/.google-play/service-account.json"),
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      validate_only: false
    )
  end
end

platform :mac do
  desc "Build and upload macOS App Store build to TestFlight"
  lane :upload_testflight do
    api_key = waisay_app_store_connect_api_key

    sh("scripts/verify-macos-channels.sh")

    build_app(
      project: "macos/WaiSay/WaiSay.xcodeproj",
      scheme: "WaiSay",
      export_method: "app-store",
      output_directory: "artifacts/testflight/macos",
      output_name: "WaiSay.pkg",
      destination: "generic/platform=macOS",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      apple_id: "6761768729",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build strict notarized DMG and publish it to say.waiwai.is"
  lane :publish_dmg do
    sh("scripts/verify-macos-channels.sh")
    sh("MACOS_RELEASE_STRICT=1 scripts/build-macos-dmg.sh")
    sh("scripts/publish-macos-dmg.sh")
  end

  desc "Upload macOS App Store build to TestFlight and publish direct DMG to web"
  lane :upload_all do
    upload_testflight
    publish_dmg
  end

  desc "Upload macOS metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = waisay_app_store_connect_api_key

    deliver(
      api_key: api_key,
      platform: "osx",
      app_identifier: "is.waiwai.say",
      screenshots_path: "fastlane/screenshots_macos",
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
