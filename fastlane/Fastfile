default_platform(:ios)

platform :ios do
  desc "Upload iOS metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: "TND8C962YA",
      issuer_id: "db1b8a2b-2870-44dc-baf5-bbc2a17db1a3",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_TND8C962YA.p8"),
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.say",
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Submit latest uploaded iOS build for App Review"
  lane :submit_for_review do |options|
    api_key = app_store_connect_api_key(
      key_id: "TND8C962YA",
      issuer_id: "db1b8a2b-2870-44dc-baf5-bbc2a17db1a3",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_TND8C962YA.p8"),
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.say",
      build_number: options[:build_number],
      app_version: options[:app_version] || "1.0.3",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end

platform :android do
  desc "Upload Android AAB to Google Play internal track"
  lane :upload_internal do
    upload_to_play_store(
      package_name: "is.waiwai.say",
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key: File.expand_path("~/.google-play/service-account.json"),
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      validate_only: false
    )
  end
end

platform :mac do
  desc "Upload macOS metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: "TND8C962YA",
      issuer_id: "db1b8a2b-2870-44dc-baf5-bbc2a17db1a3",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_TND8C962YA.p8"),
      in_house: false
    )

    deliver(
      api_key: api_key,
      platform: "osx",
      app_identifier: "is.waiwai.say",
      screenshots_path: "fastlane/screenshots_macos",
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
