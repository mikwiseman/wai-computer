require "json"
require "shellwords"

default_platform(:ios)

def repo_root
  File.expand_path("..", __dir__)
end

def strip_quarantine_attributes(*paths)
  paths.each do |path|
    next unless File.exist?(path)

    sh("find #{path.shellescape} -xattrname com.apple.quarantine -exec xattr -d com.apple.quarantine {} +")
  end
end

def waisay_app_store_connect_api_key
  config_path = File.expand_path("$APPSTORECONNECT_CONFIG")
  config = JSON.parse(File.read(config_path))

  app_store_connect_api_key(
    key_id: config.fetch("key_id"),
    issuer_id: config.fetch("issuer_id"),
    key_filepath: File.expand_path(config.fetch("key_filepath")),
    in_house: false
  )
end

platform :ios do
  desc "Upload iOS metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = waisay_app_store_connect_api_key

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.say",
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Submit latest uploaded iOS build for App Review"
  lane :submit_for_review do |options|
    api_key = waisay_app_store_connect_api_key

    deliver(
      api_key: api_key,
      app_identifier: "is.waiwai.say",
      build_number: options[:build_number],
      app_version: options[:app_version] || "1.0.3",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end

platform :android do
  desc "Upload Android AAB to Google Play internal track"
  lane :upload_internal do
    upload_to_play_store(
      package_name: "is.waiwai.say",
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key: File.expand_path("$GOOGLE_PLAY_JSON_KEY"),
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      validate_only: false
    )
  end
end

platform :mac do
  desc "Build and upload macOS App Store build to TestFlight"
  lane :upload_testflight do
    api_key = waisay_app_store_connect_api_key
    pkg_path = File.join(repo_root, "artifacts/testflight/macos/WaiSay.pkg")

    strip_quarantine_attributes(
      File.join(repo_root, "macos/WaiSay/WaiSay/AppIcon.icon"),
      File.join(repo_root, "macos/WaiSay/WaiSay/Assets.xcassets"),
      File.join(repo_root, "ios/WaiSay/WaiSay/AppIcon.icon"),
      File.join(repo_root, "ios/WaiSay/WaiSay/Assets.xcassets")
    )
    sh(File.join(repo_root, "scripts/verify-macos-channels.sh"))

    build_app(
      project: File.join(repo_root, "macos/WaiSay/WaiSay.xcodeproj"),
      scheme: "WaiSay",
      export_method: "app-store",
      output_directory: File.dirname(pkg_path),
      output_name: "WaiSay",
      destination: "generic/platform=macOS",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      apple_id: "6761768729",
      pkg: Actions.lane_context[SharedValues::PKG_OUTPUT_PATH] || pkg_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build strict notarized DMG and publish it to say.waiwai.is"
  lane :publish_dmg do
    strip_quarantine_attributes(
      File.join(repo_root, "macos/WaiSay/WaiSay/AppIcon.icon"),
      File.join(repo_root, "macos/WaiSay/WaiSay/Assets.xcassets")
    )
    sh(File.join(repo_root, "scripts/verify-macos-channels.sh"))
    sh("MACOS_RELEASE_STRICT=1 #{File.join(repo_root, "scripts/build-macos-dmg.sh")}")
    sh(File.join(repo_root, "scripts/publish-macos-dmg.sh"))
  end

  desc "Upload macOS App Store build to TestFlight and publish direct DMG to web"
  lane :upload_all do
    upload_testflight
    publish_dmg
  end

  desc "Upload macOS metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = waisay_app_store_connect_api_key

    deliver(
      api_key: api_key,
      platform: "osx",
      app_identifier: "is.waiwai.say",
      screenshots_path: File.join(repo_root, "fastlane/screenshots_macos"),
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
