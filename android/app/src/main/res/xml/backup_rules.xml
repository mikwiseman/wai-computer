<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto Backup rules (Android 6-11 fallback).
  Exclude tokens, recordings, and the EncryptedSharedPreferences blob
  so cloud backup never leaks credentials or audio bytes.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="secure_tokens.xml" />
    <exclude domain="sharedpref" path="encrypted_prefs.xml" />
    <exclude domain="file" path="datastore/" />
    <exclude domain="file" path="recordings/" />
    <exclude domain="file" path="pending_transcripts/" />
</full-backup-content>
