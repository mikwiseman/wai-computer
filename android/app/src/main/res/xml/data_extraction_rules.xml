<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup / device-transfer rules (Android 12+).
  Mirrors backup_rules.xml: never include tokens, recordings, or
  preference DataStore in cloud backup or device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_tokens.xml" />
        <exclude domain="sharedpref" path="encrypted_prefs.xml" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="recordings/" />
        <exclude domain="file" path="pending_transcripts/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_tokens.xml" />
        <exclude domain="sharedpref" path="encrypted_prefs.xml" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="recordings/" />
        <exclude domain="file" path="pending_transcripts/" />
    </device-transfer>
</data-extraction-rules>
