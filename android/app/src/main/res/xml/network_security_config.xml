<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production traffic: TLS only against system CAs.
         No user-installed CAs to defend against on-device interception. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Pin the canonical host explicitly. Cleartext is forbidden everywhere. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">wai.computer</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Debug builds may target localhost / staging hosts over plain HTTP.
         Release builds inherit base-config above. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
