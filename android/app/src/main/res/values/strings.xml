    <string name="settings_mcp_subtitle">Connect AI assistants to your recordings</string>
    <string name="settings_mcp_open">Set up MCP</string>
    <string name="settings_mcp_explainer">WaiComputer exposes an MCP (Model Context Protocol) server. Connect any MCP-compatible AI assistant to give it read-only access to your recordings, transcripts, summaries, action items, and metadata. You approve each client by name on wai.computer and can revoke any time from the client itself.</string>
