default_platform(:mac)
require "shellwords"

def waisay_app_store_connect_api_key
  app_store_connect_api_key(
    key_id: "<app-store-key-id>",
    issuer_id: "<app-store-issuer-id>",
    key_filepath: File.expand_path("$APPSTORECONNECT_CONFIG"),
    in_house: false
  )
end

def waisay_repo_root
  File.expand_path("../../..", __dir__)
end

platform :mac do
  desc "Build and upload to TestFlight"
  lane :testflight_upload do
    api_key = waisay_app_store_connect_api_key

    sh("cd #{waisay_repo_root.shellescape} && scripts/verify-macos-channels.sh")

    build_app(
      project: "WaiSay.xcodeproj",
      scheme: "WaiSay",
      export_method: "app-store",
      output_directory: "build",
      output_name: "WaiSay.pkg",
      destination: "generic/platform=macOS",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      apple_id: "6761768729",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build strict notarized DMG and publish it to say.waiwai.is"
  lane :publish_dmg do
    sh("cd #{waisay_repo_root.shellescape} && scripts/verify-macos-channels.sh")
    sh("cd #{waisay_repo_root.shellescape} && MACOS_RELEASE_STRICT=1 scripts/build-macos-dmg.sh")
    sh("cd #{waisay_repo_root.shellescape} && scripts/publish-macos-dmg.sh")
  end

  desc "Upload macOS App Store build to TestFlight and publish direct DMG to web"
  lane :upload_all do
    testflight_upload
    publish_dmg
  end
end
