    "billing.cap.exceeded.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've used this week's free transcription. Upgrade to Pro for unlimited usage, or wait until Sunday for the next reset."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лимит бесплатной транскрипции на эту неделю исчерпан. Оформи Pro, чтобы пользоваться без ограничений, или подожди до воскресенья — лимит сбрасывается."
          }
        }
      }
    },
